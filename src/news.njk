---
pagination:
  data: locales
  size: 1
  alias: localeCode
permalink: "/{{ localeCode }}/news/index.html"
layout: base.njk
activePage: news
seoTitle: "seo.news_title"
seoDesc: "seo.news_desc"
eleventyComputed:
  lang: "{{ localeCode }}"
---


<section class="page-header">
  <div class="container">
    <h1>{{ "news_page.title_main" | t(locales, lang) | safe }}</h1>
    <p>{{ "news_page.subtitle" | t(locales, lang) | safe }}</p>
  </div>
</section>

<section class="section">
  <div class="container" style="max-width:800px">
    <div class="news-grid" id="news-list">
      {% set articles = collections.article %}
      {% if articles %}
        {% for item in articles | reverse %}
          {% if item.page.lang == localeCode %}
            <article class="news-card">
              <a href="{{ item.url }}" class="news-card-link"></a>
              {% if item.data.image %}
              <div class="news-card-image-wrap">
                <div class="news-card-image" style="background-image: url('{{ item.data.image }}');"></div>
              </div>
              {% endif %}
              <div class="news-card-content">
                <span class="news-card-date">{{ item.date | dateIso }}</span>
                <h3 class="news-card-title">{{ item.data.title }}</h3>
                {% if item.data.excerpt %}
                <p class="news-card-excerpt">{{ item.data.excerpt }}</p>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      {% else %}
        <p class="no-news-msg">{{ "news.no_articles" | t(locales, localeCode) }}</p>
      {% endif %}
    </div>
  </div>
</section>
