---
pagination:
  data: locales
  size: 1
  alias: localeCode
permalink: "/{{ localeCode }}/news/index.html"
layout: base.njk
activePage: news
eleventyComputed:
  lang: "{{ localeCode }}"
---


<section class="page-header">
  <div class="container">
    <h1>News &amp; Updates</h1>
    <p>Follow the progress of the Knowledge Ark Initiative.</p>
  </div>
</section>

<section class="section">
  <div class="container" style="max-width:800px">
    <div class="news-grid" id="news-list">
      {% set articles = collections.article %}
      {% if articles %}
        {% for item in articles | reverse %}
          {% if item.page.lang == localeCode %}
            <article class="news-card" {% if item.data.image %}style="background-image: linear-gradient(to top, rgba(14, 16, 21, 0.95) 0%, rgba(14, 16, 21, 0.75) 50%, rgba(14, 16, 21, 0.5) 100%), url('{{ item.data.image }}'); background-size: cover; background-position: center;"{% endif %}>
              <a href="{{ item.url }}" class="news-card-link"></a>
              <div class="news-card-content">
                <span class="news-card-date">{{ item.date | dateIso }}</span>
                <h3 class="news-card-title">{{ item.data.title }}</h3>
                {% if item.data.excerpt %}
                <p class="news-card-excerpt">{{ item.data.excerpt }}</p>
                {% endif %}
              </div>
            </article>
          {% endif %}
        {% endfor %}
      {% else %}
        <p class="no-news-msg">{{ "news.no_articles" | t(locales, localeCode) }}</p>
      {% endif %}
    </div>
  </div>
</section>
