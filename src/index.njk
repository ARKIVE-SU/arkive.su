---
pagination:
  data: locales
  size: 1
  alias: localeCode
permalink: "/{{ localeCode }}/index.html"
layout: base.njk
activePage: home
eleventyComputed:
  lang: "{{ localeCode }}"
---

<!-- ===== HERO ===== -->
<section class="hero">
  <div class="container">
    <h1><span>{{ "hero.title_part1" | t(locales, lang) | safe }}</span><br><span class="gold">{{ "hero.title_part2" | t(locales, lang) | safe }}</span></h1>
    <p class="hero-subtitle">
      {{ "hero.subtitle" | t(locales, lang) | safe }}
    </p>
    <div class="btn-group">
      <a href="/{{ lang }}/participate/" class="btn btn-primary">{{ "hero.btn_network" | t(locales, lang) | safe }}</a>
      <a href="/{{ lang }}/mission/" class="btn btn-outline">{{ "hero.btn_mission" | t(locales, lang) | safe }}</a>
    </div>
  </div>
</section>

<!-- ===== STATS ===== -->
<section class="section" style="padding-top:0">
  <div class="container">
    <div class="stats">
      <div class="stat-item">
        <span class="stat-number">200+</span>
        <span class="stat-label">{{ "stats.institutions" | t(locales, lang) | safe }}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">6</span>
        <span class="stat-label">{{ "stats.continents" | t(locales, lang) | safe }}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">3</span>
        <span class="stat-label">{{ "stats.tech" | t(locales, lang) | safe }}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">{{ "stats.earth_space" | t(locales, lang) | safe }}</span>
        <span class="stat-label">{{ "stats.redundancy" | t(locales, lang) | safe }}</span>
      </div>
    </div>
  </div>
</section>

<!-- ===== THREE PILLARS ===== -->
<section class="section pillars">
  <div class="container">
    <h2 class="section-title">{{ "pillars.title" | t(locales, lang) | safe }}</h2>
    <div class="grid-3">
      <div class="card">
        <h3>{{ "pillars.knowledge_holders_title" | t(locales, lang) | safe }}</h3>
        <p>{{ "pillars.knowledge_holders_desc" | t(locales, lang) | safe }}</p>
      </div>
      <div class="card">
        <h3>{{ "pillars.technology_drivers_title" | t(locales, lang) | safe }}</h3>
        <p>{{ "pillars.technology_drivers_desc" | t(locales, lang) | safe }}</p>
      </div>
      <div class="card">
        <h3>{{ "pillars.infrastructure_nodes_title" | t(locales, lang) | safe }}</h3>
        <p>{{ "pillars.infrastructure_nodes_desc" | t(locales, lang) | safe }}</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== HOW IT WORKS ===== -->
<section class="section" style="background: var(--bg-secondary)">
  <div class="container">
    <h2 class="section-title">{{ "how_it_works.title" | t(locales, lang) | safe }}</h2>
    <div class="steps">
      <div class="step">
        <h4>{{ "how_it_works.step1_title" | t(locales, lang) | safe }}</h4>
        <p>{{ "how_it_works.step1_desc" | t(locales, lang) | safe }}</p>
      </div>
      <div class="step">
        <h4>{{ "how_it_works.step2_title" | t(locales, lang) | safe }}</h4>
        <p>{{ "how_it_works.step2_desc" | t(locales, lang) | safe }}</p>
      </div>
      <div class="step">
        <h4>{{ "how_it_works.step3_title" | t(locales, lang) | safe }}</h4>
        <p>{{ "how_it_works.step3_desc" | t(locales, lang) | safe }}</p>
      </div>
      <div class="step">
        <h4>{{ "how_it_works.step4_title" | t(locales, lang) | safe }}</h4>
        <p>{{ "how_it_works.step4_desc" | t(locales, lang) | safe }}</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== FORMULA ===== -->
<section class="section">
  <div class="container" style="text-align:center">
    <h2 class="section-title">{{ "formula.title" | t(locales, lang) | safe }}</h2>
    <p style="font-size:1.3rem; color: var(--text-primary); font-family: var(--font-serif); max-width:700px; margin:0 auto 1.5rem;">
      {{ "formula.equation" | t(locales, lang) | safe }}
    </p>
    <p style="max-width:600px; margin:0 auto;">
      {{ "formula.desc" | t(locales, lang) | safe }}
    </p>
  </div>
</section>

<!-- ===== TELEGRAM PROMO ===== -->
<section class="section" style="background: var(--bg-tertiary); max-width: 800px; margin: 0 auto; padding: 3rem 1.5rem; text-align: center; border-radius: 12px; border: 1px solid rgba(255,255,255,0.1); margin-bottom: 2rem;">
  <div class="container">
    <svg width="48" height="48" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg" style="color: var(--text-primary); margin-bottom: 1rem;">
      <path d="M22 44C9.84974 44 0 34.1503 0 22C0 9.84974 9.84974 0 22 0C34.1503 0 44 9.84974 44 22C44 34.1503 34.1503 44 22 44ZM22.9513 16.5101C20.9809 17.3297 17.043 19.0259 11.1374 21.5989C10.1784 21.9803 9.67606 22.3533 9.63033 22.7181C9.55304 23.3346 10.3251 23.5774 11.3764 23.908C11.5194 23.9529 11.6676 23.9995 11.8195 24.0489C12.8538 24.3851 14.2452 24.7785 14.9685 24.7941C15.6246 24.8083 16.3569 24.5378 17.1653 23.9826C22.6831 20.258 25.5314 18.3754 25.7102 18.3348C25.8364 18.3061 26.0112 18.2701 26.1296 18.3754C26.2481 18.4807 26.2365 18.6801 26.2239 18.7336C26.1474 19.0596 23.1169 21.8771 21.9083 22.9846C21.7347 23.1437 21.6111 23.3601 21.5645 23.5936C21.4647 24.1687 23.0035 25.1764 24.6406 26.2415C25.3228 26.6853 25.9388 27.086 26.398 27.3995C26.7936 27.6715 27.234 27.8687 27.6974 27.9818C28.2166 28.1066 28.7661 28.0838 29.2731 27.9157C29.7423 27.7607 30.2223 26.7865 30.7077 24.7735C31.5273 21.3664 33.1595 11.7517 33.5135 8.65084C33.528 8.49071 33.5235 8.3292 33.4999 8.1691C33.4566 7.7371 33.2759 7.33083 32.981 7.0016C32.7441 6.74567 32.4278 6.57449 32.0837 6.51614C31.5177 6.42531 30.6552 6.64367 29.8339 6.8996C27.9105 7.48912 22.9513 16.5101 22.9513 16.5101Z" fill="currentColor"/>
    </svg>
    <h2 class="section-title" style="margin-bottom: 0.5rem">{{ "telegram.title" | t(locales, lang) | safe }}</h2>
    <p style="margin-bottom: 2rem">{{ "telegram.desc" | t(locales, lang) | safe }}</p>
    <a href="https://t.me/arkiveSU" target="_blank" rel="noopener noreferrer" class="btn btn-outline" style="border-color: var(--text-primary); color: var(--text-primary);">
      {{ "telegram.btn" | t(locales, lang) | safe }}
    </a>
  </div>
</section>

<!-- ===== NEWSLETTER ===== -->
<section class="section" style="background: var(--bg-secondary)">
  <div class="container" style="text-align:center">
    <h2 class="section-title">{{ "newsletter.title" | t(locales, lang) | safe }}</h2>
    <p>{{ "newsletter.subtitle" | t(locales, lang) | safe }}</p>
    <form action="#" method="POST" class="newsletter-form">
      <input type="hidden" name="form_type" value="newsletter">
      <input type="email" name="email" class="form-input" placeholder="{{ 'newsletter.placeholder' | t(locales, lang) | escape }}" required>
      <button type="submit" class="btn btn-primary">{{ "newsletter.btn" | t(locales, lang) | safe }}</button>
    </form>
  </div>
</section>
