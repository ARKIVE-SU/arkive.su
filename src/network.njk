---
pagination:
  data: locales
  size: 1
  alias: localeCode
permalink: "/{{ localeCode }}/network/index.html"
layout: base.njk
activePage: network
seoTitle: "seo.network_title"
seoDesc: "seo.network_desc"
eleventyComputed:
  lang: "{{ localeCode }}"
---


<section class="page-header">
  <div class="container">
    <h1 >{{ "network_page.title" | t(locales, lang) | safe }}</h1>
    <p >{{ "network_page.subtitle" | t(locales, lang) | safe }}</p>
  </div>
</section>

<section class="section">
  <div class="container">

    <!-- Summary stats -->
    <div class="stats" style="margin-bottom:3rem;">
      <div class="stat-item">
        <span class="stat-number">200+</span>
        <span class="stat-label" >{{ "network_page.stats_institutions" | t(locales, lang) | safe }}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">4</span>
        <span class="stat-label" >{{ "network_page.stats_categories" | t(locales, lang) | safe }}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">6</span>
        <span class="stat-label" >{{ "network_page.stats_continents" | t(locales, lang) | safe }}</span>
      </div>
    </div>

    <!-- Category overview -->
    <h2 class="section-title" >{{ "network_page.cat_title" | t(locales, lang) | safe }}</h2>
    <div class="grid-2" style="margin-bottom:3rem">
      <div class="card">
        <span class="card-badge badge-knowledge" >{{ "network_page.cat_knowledge_badge" | t(locales, lang) | safe }}</span>
        <h3 >{{ "network_page.cat_knowledge_title" | t(locales, lang) | safe }}</h3>
        <p >{{ "network_page.cat_knowledge_desc" | t(locales, lang) | safe }}</p>
      </div>
      <div class="card">
        <span class="card-badge badge-storage" >{{ "network_page.cat_tech_badge" | t(locales, lang) | safe }}</span>
        <h3 >{{ "network_page.cat_tech_title" | t(locales, lang) | safe }}</h3>
        <p >{{ "network_page.cat_tech_desc" | t(locales, lang) | safe }}</p>
      </div>
      <div class="card">
        <span class="card-badge badge-space" >{{ "network_page.cat_space_badge" | t(locales, lang) | safe }}</span>
        <h3 >{{ "network_page.cat_space_title" | t(locales, lang) | safe }}</h3>
        <p >{{ "network_page.cat_space_desc" | t(locales, lang) | safe }}</p>
      </div>
      <div class="card">
        <span class="card-badge badge-digital" >{{ "network_page.cat_digital_badge" | t(locales, lang) | safe }}</span>
        <h3 >{{ "network_page.cat_digital_title" | t(locales, lang) | safe }}</h3>
        <p >{{ "network_page.cat_digital_desc" | t(locales, lang) | safe }}</p>
      </div>
    </div>

    <!-- Anonymous Participant Stats -->
    <div style="background: var(--bg-secondary); border-radius:12px; padding:3rem; margin-top:2rem; border:1px solid rgba(255,255,255,0.05); text-align:center;">
      <h3 style="margin-bottom:2rem; font-family: var(--font-serif); font-size: 1.8rem; color: var(--text-primary);">{{ "network_page.placeholder_title" | t(locales, lang) | safe }}</h3>
      <p style="color:var(--text-secondary); max-width:600px; margin:0 auto 3rem;">{{ "network_page.placeholder_desc" | t(locales, lang) | safe }}</p>
      
      <div class="grid-2" style="gap:2rem; text-align:left; max-width:800px; margin:0 auto;">
        <div style="display:flex; align-items:center; gap:1.5rem; padding:1.5rem; background:rgba(255,255,255,0.03); border-radius:8px;">
          <div style="font-size:2.5rem; color:var(--accent-gold); font-weight:700; min-width:60px;">12</div>
          <div style="font-size:1.1rem; color:var(--text-primary);">{{ "network_stats.l" | t(locales, lang) | safe }}</div>
        </div>
        <div style="display:flex; align-items:center; gap:1.5rem; padding:1.5rem; background:rgba(255,255,255,0.03); border-radius:8px;">
          <div style="font-size:2.5rem; color:var(--accent-gold); font-weight:700; min-width:60px;">8</div>
          <div style="font-size:1.1rem; color:var(--text-primary);">{{ "network_stats.a" | t(locales, lang) | safe }}</div>
        </div>
        <div style="display:flex; align-items:center; gap:1.5rem; padding:1.5rem; background:rgba(255,255,255,0.03); border-radius:8px;">
          <div style="font-size:2.5rem; color:var(--accent-gold); font-weight:700; min-width:60px;">3</div>
          <div style="font-size:1.1rem; color:var(--text-primary);">{{ "network_stats.t" | t(locales, lang) | safe }}</div>
        </div>
        <div style="display:flex; align-items:center; gap:1.5rem; padding:1.5rem; background:rgba(255,255,255,0.03); border-radius:8px;">
          <div style="font-size:2.5rem; color:var(--accent-gold); font-weight:700; min-width:60px;">2</div>
          <div style="font-size:1.1rem; color:var(--text-primary);">{{ "network_stats.i" | t(locales, lang) | safe }}</div>
        </div>
      </div>
      
      <div style="margin-top:3rem;">
        <a href="/{{ lang }}/participate/" class="btn btn-primary" >{{ "network_page.btn_join" | t(locales, lang) | safe }}</a>
      </div>
    </div>

  </div>
</section>
