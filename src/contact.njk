---
pagination:
  data: locales
  size: 1
  alias: localeCode
permalink: "/{{ localeCode }}/contact/index.html"
layout: base.njk
activePage: contact
eleventyComputed:
  lang: "{{ localeCode }}"
---


<section class="page-header">
  <div class="container">
    <h1 >{{ "contact_page.title" | t(locales, lang) | safe }}</h1>
    <p >{{ "contact_page.subtitle" | t(locales, lang) | safe }}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="grid-2" style="gap:4rem; align-items:start;">

      <!-- Contact Form -->
      <div>
        <h2 >{{ "contact_page.msg_title" | t(locales, lang) | safe }}</h2>
        <form action="https://formspree.io/f/myknzekz" method="POST" id="contact-form" style="margin-top:1.5rem;">
          <input type="hidden" name="form_type" value="contact">
          <div class="form-group">
            <label for="contact-name" >{{ "contact_page.form_name" | t(locales, lang) | safe }}</label>
            <input type="text" id="contact-name" name="name" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="contact-email" >{{ "contact_page.form_email" | t(locales, lang) | safe }}</label>
            <input type="email" id="contact-email" name="email" class="form-input" required>
          </div>
          <div class="form-group">
            <label for="contact-subject" >{{ "contact_page.form_subject" | t(locales, lang) | safe }}</label>
            <input type="text" id="contact-subject" name="subject" class="form-input">
          </div>
          <div class="form-group">
            <label for="contact-message" >{{ "contact_page.form_msg" | t(locales, lang) | safe }}</label>
            <textarea id="contact-message" name="message" class="form-textarea" rows="6" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary" style="width:100%" >{{ "contact_page.form_btn" | t(locales, lang) | safe }}</button>
        </form>
      </div>

      <!-- Contact Info -->
      <div>
        <h2 >{{ "contact_page.other_title" | t(locales, lang) | safe }}</h2>
        <div style="margin-top:1.5rem;">
          <h4 style="color:var(--accent-gold); margin-bottom:0.5rem;" >{{ "contact_page.email_title" | t(locales, lang) | safe }}</h4>
          <p><a href="mailto:hello@arkive.su">hello@arkive.su</a></p>

          <h4 style="color:var(--accent-gold); margin-top:2rem; margin-bottom:0.5rem;" >{{ "contact_page.eoi_title" | t(locales, lang) | safe }}</h4>
          <p><span >{{ "contact_page.eoi_text" | t(locales, lang) | safe }}</span> <a href="participate.html#eoi-form" >{{ "contact_page.eoi_link" | t(locales, lang) | safe }}</a>.</p>

          <h4 style="color:var(--accent-gold); margin-top:2rem; margin-bottom:0.5rem;" >{{ "contact_page.news_title" | t(locales, lang) | safe }}</h4>
          <p >{{ "contact_page.news_text" | t(locales, lang) | safe }}</p>
          <form action="https://formspree.io/f/myknzekz" method="POST" class="newsletter-form" style="margin-top:1rem; max-width:100%;">
            <input type="hidden" name="form_type" value="newsletter">
            <input type="email" name="email" class="form-input" placeholder="{{ 'contact_page.news_placeholder' | t(locales, lang) | escape }}"  required>
            <button type="submit" class="btn btn-primary" >{{ "contact_page.news_btn" | t(locales, lang) | safe }}</button>
          </form>
        </div>
      </div>

    </div>
  </div>
</section>

