---
pagination:
  data: locales
  size: 1
  alias: localeCode
permalink: "/{{ localeCode }}/technologies/index.html"
layout: base.njk
activePage: technologies
eleventyComputed:
  lang: "{{ localeCode }}"
---

<section class="page-header">
  <div class="container">
    <h1 >{{ "tech_page.title" | t(locales, lang) | safe }}</h1>
    <p >{{ "tech_page.subtitle" | t(locales, lang) | safe }}</p>
  </div>
</section>

<section class="section">
  <div class="container">

    <div class="grid-3" style="margin-bottom:3rem">
      <div class="tech-card">
        <div class="card-icon">&#9671;</div>
        <h3 >{{ "tech_page.cera_title" | t(locales, lang) | safe }}</h3>
        <p class="tech-subtitle" >{{ "tech_page.cera_sub" | t(locales, lang) | safe }}</p>
        <ul class="tech-specs">
          <li >{{ "tech_page.cera_li1" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.cera_li2" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.cera_li3" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.cera_li4" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.cera_li5" | t(locales, lang) | safe }}</li>
        </ul>
        <p style="margin-top:1.5rem; font-size:0.9rem;" >{{ "tech_page.cera_desc" | t(locales, lang) | safe }}</p>
      </div>

      <div class="tech-card">
        <div class="card-icon">&#10022;</div>
        <h3 >{{ "tech_page.spho_title" | t(locales, lang) | safe }}</h3>
        <p class="tech-subtitle" >{{ "tech_page.spho_sub" | t(locales, lang) | safe }}</p>
        <ul class="tech-specs">
          <li >{{ "tech_page.spho_li1" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.spho_li2" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.spho_li3" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.spho_li4" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.spho_li5" | t(locales, lang) | safe }}</li>
        </ul>
      </div>

      <div class="tech-card">
        <div class="card-icon">&#9789;</div>
        <h3 >{{ "tech_page.lone_title" | t(locales, lang) | safe }}</h3>
        <p class="tech-subtitle" >{{ "tech_page.lone_sub" | t(locales, lang) | safe }}</p>
        <ul class="tech-specs">
          <li >{{ "tech_page.lone_li1" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.lone_li2" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.lone_li3" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.lone_li4" | t(locales, lang) | safe }}</li>
          <li >{{ "tech_page.lone_li5" | t(locales, lang) | safe }}</li>
        </ul>
      </div>
    </div>

    <!-- Multi-redundancy -->
    <div style="background: var(--bg-secondary); border-radius:8px; padding:3rem; text-align:center; border:1px solid var(--border-color);">
      <h2 style="margin-bottom:1.5rem" >{{ "tech_page.multi_title" | t(locales, lang) | safe }}</h2>
      <p style="max-width:700px; margin:0 auto 2rem; font-size:1.05rem;" >{{ "tech_page.multi_subtitle" | t(locales, lang) | safe }}</p>
      <div class="grid-3" style="gap:2rem; text-align:left;">
        <div>
          <h4 style="color:var(--accent-gold); margin-bottom:0.5rem;" >{{ "tech_page.multi_media_title" | t(locales, lang) | safe }}</h4>
          <p style="font-size:0.9rem;" >{{ "tech_page.multi_media_desc" | t(locales, lang) | safe }}</p>
        </div>
        <div>
          <h4 style="color:var(--accent-gold); margin-bottom:0.5rem;" >{{ "tech_page.multi_geo_title" | t(locales, lang) | safe }}</h4>
          <p style="font-size:0.9rem;" >{{ "tech_page.multi_geo_desc" | t(locales, lang) | safe }}</p>
        </div>
        <div>
          <h4 style="color:var(--accent-gold); margin-bottom:0.5rem;" >{{ "tech_page.multi_format_title" | t(locales, lang) | safe }}</h4>
          <p style="font-size:0.9rem;" >{{ "tech_page.multi_format_desc" | t(locales, lang) | safe }}</p>
        </div>
      </div>
    </div>

    <div style="text-align:center; margin-top:3rem;">
      <p style="color: var(--text-muted); font-size:0.95rem; margin-bottom:1.5rem;" >{{ "tech_page.footer_p" | t(locales, lang) | safe }}</p>
      <a href="/{{ lang }}/participate/" class="btn btn-primary" >{{ "tech_page.btn_propose" | t(locales, lang) | safe }}</a>
    </div>

  </div>
</section>
