<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ 'rtl' if lang == 'ar' else 'ltr' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ "meta.title" | t(locales, lang) }}</title>
  <meta name="description" content="{{ "meta.description" | t(locales, lang) }}">
  <meta name="robots" content="index, follow">
  <meta property="og:title" content="{{ "meta.title" | t(locales, lang) }}">
  <meta property="og:description" content="{{ "meta.description" | t(locales, lang) }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://arkive.su{{ page.url }}">
  <meta property="og:image" content="https://arkive.su/assets/images/titanium-shoulder.jpg">
  <meta property="og:locale" content="{% if lang == 'en' %}en_US{% elif lang == 'ru' %}ru_RU{% elif lang == 'es' %}es_ES{% elif lang == 'zh' %}zh_CN{% elif lang == 'ar' %}ar_SA{% endif %}">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ "meta.title" | t(locales, lang) }}">
  <meta name="twitter:description" content="{{ "meta.description" | t(locales, lang) }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Onest:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="stylesheet" href="/assets/css/main.css?v=4.0">

  <!-- Canonical & Hreflang -->
  <link rel="canonical" href="https://arkive.su{{ page.url }}">
  <link rel="alternate" hreflang="en" href="https://arkive.su{{ page.url | langUrl('en') }}">
  <link rel="alternate" hreflang="ru" href="https://arkive.su{{ page.url | langUrl('ru') }}">
  <link rel="alternate" hreflang="es" href="https://arkive.su{{ page.url | langUrl('es') }}">
  <link rel="alternate" hreflang="zh" href="https://arkive.su{{ page.url | langUrl('zh') }}">
  <link rel="alternate" hreflang="ar" href="https://arkive.su{{ page.url | langUrl('ar') }}">
  <link rel="alternate" hreflang="x-default" href="https://arkive.su{{ page.url | langUrl('en') }}">

  <!-- Search Engine Verification -->
  <meta name="google-site-verification" content="I94D3hPYQ7IN2c133WzF4db3mrFwP20o4pF4eAItbWw">
  <meta name="yandex-verification" content="c5525f8666faf2a7">
  <meta name="msvalidate.01" content="B89AA3BB32B92D09D5227D6E1FB1AFBC">
  <!-- <meta name="baidu-site-verification" content="XXXX"> -->
  <!-- <meta name="naver-site-verification" content="XXXX"> -->

  <!-- JSON-LD Organization Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Knowledge Ark Initiative",
    "alternateName": "ARKIVE.SU",
    "url": "https://arkive.su",
    "logo": "https://arkive.su/assets/images/logo.png",
    "description": "A decentralised initiative to preserve humanity's most important knowledge across multiple storage media and locations — on Earth and in space.",
    "sameAs": [
      "https://t.me/arkiveSU"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "hello@arkive.su",
      "contactType": "general"
    }
  }
  </script>

  <!-- Analytics -->
  <!-- Google Analytics 4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-M6Y1MJY3M5"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-M6Y1MJY3M5');</script>

  <!-- Yandex Metrica -->
  <script type="text/javascript">
    (function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};m[i].l=1*new Date();for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})(window,document,"script","https://mc.yandex.ru/metrika/tag.js","ym");
    ym(107224604,"init",{clickmap:true,trackLinks:true,accurateTrackBounce:true,webvisor:true});
  </script>
  <noscript><div><img src="https://mc.yandex.ru/watch/107224604" style="position:absolute; left:-9999px;" alt="" /></div></noscript>

</head>
<body>

<header class="header">
  <nav class="nav">
    <a href="/{{ lang }}/" class="nav-logo">
      <img src="/assets/images/logo.png" alt="Knowledge Ark Logo" id="site-logo" loading="lazy">
    </a>
    <ul class="nav-links">
      <li><a href="/{{ lang }}/" class="{% if activePage == 'home' %}active{% endif %}">{{ "nav.home" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/mission/" class="{% if activePage == 'mission' %}active{% endif %}">{{ "nav.mission" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/technologies/" class="{% if activePage == 'technologies' %}active{% endif %}">{{ "nav.technologies" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/network/" class="{% if activePage == 'network' %}active{% endif %}">{{ "nav.network" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/participate/" class="{% if activePage == 'participate' %}active{% endif %}">{{ "nav.participate" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/news/" class="{% if activePage == 'news' %}active{% endif %}">{{ "nav.news" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/faq/" class="{% if activePage == 'faq' %}active{% endif %}">{{ "nav.faq" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/contact/" class="{% if activePage == 'contact' %}active{% endif %}">{{ "nav.contact" | t(locales, lang) }}</a></li>
    </ul>
    
    <div class="social-links">
      <a href="https://t.me/arkiveSU" target="_blank" rel="noopener noreferrer" aria-label="Telegram" title="Telegram">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 44 44" fill="currentColor">
          <path d="M22 44C9.84974 44 0 34.1503 0 22C0 9.84974 9.84974 0 22 0C34.1503 0 44 9.84974 44 22C44 34.1503 34.1503 44 22 44ZM22.9513 16.5101C20.9809 17.3297 17.043 19.0259 11.1374 21.5989C10.1784 21.9803 9.67606 22.3533 9.63033 22.7181C9.55304 23.3346 10.3251 23.5774 11.3764 23.908C11.5194 23.9529 11.6676 23.9995 11.8195 24.0489C12.8538 24.3851 14.2452 24.7785 14.9685 24.7941C15.6246 24.8083 16.3569 24.5378 17.1653 23.9826C22.6831 20.258 25.5314 18.3754 25.7102 18.3348C25.8364 18.3061 26.0112 18.2701 26.1296 18.3754C26.2481 18.4807 26.2365 18.6801 26.2239 18.7336C26.1474 19.0596 23.1169 21.8771 21.5486 23.3351C21.0597 23.7896 20.7129 24.1121 20.642 24.1857C20.4832 24.3506 20.3213 24.5067 20.1658 24.6566C19.2048 25.583 18.4843 26.2776 20.2057 27.412C21.0329 27.9571 21.6949 28.4079 22.3553 28.8577C23.0765 29.3488 23.7958 29.8387 24.7265 30.4488C24.9637 30.6042 25.1901 30.7657 25.4107 30.9229C26.25 31.5213 27.0041 32.0589 27.9357 31.9731C28.477 31.9233 29.0361 31.4143 29.3201 29.8962C29.9912 26.3086 31.3104 18.5351 31.6152 15.3319C31.6419 15.0512 31.6083 14.6921 31.5813 14.5344C31.5544 14.3767 31.498 14.1521 31.293 13.9858C31.0503 13.7889 30.6756 13.7473 30.508 13.7501C29.7461 13.7637 28.5771 14.1702 22.9513 16.5101Z" />
        </svg>
      </a>
    </div>

    <div class="lang-switcher">
      <select id="lang-selector" class="lang-select" onchange="window.location.href=this.value">
        <option value="{{ page.url | langUrl('en') }}" {% if lang == 'en' %}selected{% endif %}>En</option>
        <option value="{{ page.url | langUrl('ru') }}" {% if lang == 'ru' %}selected{% endif %}>Ru</option>
        <option value="{{ page.url | langUrl('es') }}" {% if lang == 'es' %}selected{% endif %}>Es</option>
        <option value="{{ page.url | langUrl('zh') }}" {% if lang == 'zh' %}selected{% endif %}>Zh</option>
        <option value="{{ page.url | langUrl('ar') }}" {% if lang == 'ar' %}selected{% endif %}>Ar</option>
      </select>
    </div>

    <button class="nav-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

{{ content | safe }}

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-about">
        <div class="footer-brand">Knowledge Ark</div>
        <p>{{ "footer.about" | t(locales, lang) }}</p>
      </div>
      <div>
        <h4>{{ "footer.navigate" | t(locales, lang) }}</h4>
        <ul class="footer-links">
          <li><a href="/{{ lang }}/mission/">{{ "nav.mission" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/technologies/">{{ "nav.technologies" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/participate/">{{ "nav.participate" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/faq/">{{ "nav.faq" | t(locales, lang) }}</a></li>
        </ul>
      </div>
      <div>
        <h4>{{ "footer.connect" | t(locales, lang) }}</h4>
        <ul class="footer-links">
          <li><a href="/{{ lang }}/contact/">{{ "nav.contact" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/news/">{{ "nav.news" | t(locales, lang) }}</a></li>
          <li><a href="https://t.me/arkiveSU" target="_blank" rel="noopener noreferrer">{{ "footer.telegram" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/participate/#eoi-section">{{ "footer.eoi" | t(locales, lang) }}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; 2026 {{ "footer.copyright" | t(locales, lang) }}
    </div>
  </div>
</footer>

<script src="/assets/js/main.js"></script>
</body>
</html>
