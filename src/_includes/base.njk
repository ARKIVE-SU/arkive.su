<!DOCTYPE html>
<html lang="{{ lang }}" dir="{{ 'rtl' if lang == 'ar' else 'ltr' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Knowledge Ark — Preserving Humanity's Knowledge for Eternity") }}</title>
  <meta name="description" content="{{ description | default('A decentralised initiative to preserve humanity\'s most important knowledge across multiple storage media and locations — on Earth and in space.') }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/png" href="/favicon.png">
  <link rel="stylesheet" href="/assets/css/main.css?v=3.1">

  <!-- Canonical & Hreflang -->
  <link rel="canonical" href="https://arkive.su{{ page.url }}">
  <link rel="alternate" hreflang="en" href="https://arkive.su{{ page.url | langUrl('en') }}">
  <link rel="alternate" hreflang="ru" href="https://arkive.su{{ page.url | langUrl('ru') }}">
  <link rel="alternate" hreflang="es" href="https://arkive.su{{ page.url | langUrl('es') }}">
  <link rel="alternate" hreflang="zh" href="https://arkive.su{{ page.url | langUrl('zh') }}">
  <link rel="alternate" hreflang="ar" href="https://arkive.su{{ page.url | langUrl('ar') }}">
  <link rel="alternate" hreflang="x-default" href="https://arkive.su{{ page.url | langUrl('en') }}">

  <!-- Search Engine Verification (replace XXXX with actual codes) -->
  <!-- <meta name="google-site-verification" content="XXXX"> -->
  <!-- <meta name="yandex-verification" content="XXXX"> -->
  <!-- <meta name="msvalidate.01" content="XXXX"> -->
  <!-- <meta name="baidu-site-verification" content="XXXX"> -->
  <!-- <meta name="naver-site-verification" content="XXXX"> -->

  <!-- JSON-LD Organization Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Knowledge Ark Initiative",
    "alternateName": "ARKIVE.SU",
    "url": "https://arkive.su",
    "logo": "https://arkive.su/assets/images/logo-placeholder.png",
    "description": "A decentralised initiative to preserve humanity's most important knowledge across multiple storage media and locations — on Earth and in space.",
    "sameAs": [
      "https://t.me/arkiveSU"
    ],
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "hello@arkive.su",
      "contactType": "general"
    }
  }
  </script>

  <!-- Analytics (replace with actual IDs) -->
  <!-- Google Analytics 4 -->
  <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXXXX"></script>
  <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-XXXXXXXXXX');</script> -->

  <!-- Yandex Metrica -->
  <!-- <script>(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};m[i].l=1*new Date();for(var j=0;j<document.scripts.length;j++){if(document.scripts[j].src===r){return;}}k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})(window,document,"script","https://mc.yandex.ru/metrika/tag.js","ym");ym(XXXXXXXX,"init",{clickmap:true,trackLinks:true,accurateTrackBounce:true,webvisor:true});</script> -->

</head>
<body>

<header class="header">
  <nav class="nav">
    <a href="/{{ lang }}/" class="nav-logo">
      <img src="/assets/images/logo-placeholder.png" alt="Knowledge Ark Logo" id="site-logo">
    </a>
    <ul class="nav-links">
      <li><a href="/{{ lang }}/" class="{% if activePage == 'home' %}active{% endif %}">{{ "nav.home" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/mission/" class="{% if activePage == 'mission' %}active{% endif %}">{{ "nav.mission" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/technologies/" class="{% if activePage == 'technologies' %}active{% endif %}">{{ "nav.technologies" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/network/" class="{% if activePage == 'network' %}active{% endif %}">{{ "nav.network" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/participate/" class="{% if activePage == 'participate' %}active{% endif %}">{{ "nav.participate" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/news/" class="{% if activePage == 'news' %}active{% endif %}">{{ "nav.news" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/faq/" class="{% if activePage == 'faq' %}active{% endif %}">{{ "nav.faq" | t(locales, lang) }}</a></li>
      <li><a href="/{{ lang }}/contact/" class="{% if activePage == 'contact' %}active{% endif %}">{{ "nav.contact" | t(locales, lang) }}</a></li>
    </ul>
    
    <div class="social-links" style="margin-right: 15px; display: flex; align-items: center;">
      <a href="https://t.me/arkiveSU" target="_blank" rel="noopener noreferrer" style="color: var(--text-primary); text-decoration: none;" aria-label="Telegram" title="Telegram">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21.198 2.433a2.242 2.242 0 0 0-1.022.215l-18.068 7.034C.802 10.19.789 11.238 1.9 11.666l4.246 1.341 2.27 7.05v-.002cl.004.015.013.018.026.009L11.5 16.994l5.378 3.991a2.247 2.247 0 0 0 3.394-1.282l3.414-16.036a2.247 2.247 0 0 0-2.488-2.61ZM20.449 4.88 5.617 10.635l-3.376-1.066 17.524-6.82-1.848 10.9-8.498-5.748-1.503 1.258 6.946 6.34-3.57 1.838-.9-4.234z"></path>
<path d="M21.198 2.433a2.242 2.242 0 0 0-1.022.215l-18.068 7.034C.802 10.19.789 11.238 1.9 11.666l4.246 1.341 2.27 7.05v-.002c.004.015.016.018.03.009L11.5 16.994l5.378 3.991a2.247 2.247 0 0 0 3.394-1.282l3.414-16.036a2.247 2.247 0 0 0-2.488-2.61v.001Z" fill="currentColor"></path>
        </svg>
      </a>
    </div>

    <div class="lang-switcher">
      <select id="lang-selector" class="lang-select" onchange="window.location.href=this.value">
        <option value="{{ page.url | langUrl('en') }}" {% if lang == 'en' %}selected{% endif %}>En</option>
        <option value="{{ page.url | langUrl('ru') }}" {% if lang == 'ru' %}selected{% endif %}>Ru</option>
        <option value="{{ page.url | langUrl('es') }}" {% if lang == 'es' %}selected{% endif %}>Es</option>
        <option value="{{ page.url | langUrl('zh') }}" {% if lang == 'zh' %}selected{% endif %}>Zh</option>
        <option value="{{ page.url | langUrl('ar') }}" {% if lang == 'ar' %}selected{% endif %}>Ar</option>
      </select>
    </div>

    <button class="nav-toggle" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>
</header>

{{ content | safe }}

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-about">
        <div class="nav-logo" style="margin-bottom:0.5rem"><span>&#9670;</span> Knowledge Ark</div>
        <p>{{ "footer.about" | t(locales, lang) }}</p>
      </div>
      <div>
        <h4>{{ "footer.navigate" | t(locales, lang) }}</h4>
        <ul class="footer-links">
          <li><a href="/{{ lang }}/mission/">{{ "nav.mission" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/technologies/">{{ "nav.technologies" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/participate/">{{ "nav.participate" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/faq/">{{ "nav.faq" | t(locales, lang) }}</a></li>
        </ul>
      </div>
      <div>
        <h4>{{ "footer.connect" | t(locales, lang) }}</h4>
        <ul class="footer-links">
          <li><a href="/{{ lang }}/contact/">{{ "nav.contact" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/news/">{{ "nav.news" | t(locales, lang) }}</a></li>
          <li><a href="https://t.me/arkiveSU" target="_blank" rel="noopener noreferrer">{{ "footer.telegram" | t(locales, lang) }}</a></li>
          <li><a href="/{{ lang }}/participate/#eoi-section">{{ "footer.eoi" | t(locales, lang) }}</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      &copy; 2026 {{ "footer.copyright" | t(locales, lang) }}
    </div>
  </div>
</footer>

<script src="/assets/js/main.js"></script>
</body>
</html>
